# Database
DATABASE_URL=sqlite+aiosqlite:///./test.db

# OIDC / Auth (mock o desactivado en local)
OIDC_ENABLED=false
OIDC_CLIENT_ID=dev-client
OIDC_CLIENT_SECRET=dev-secret
OIDC_ISSUER_URL=http://localhost
OIDC_AUTHORIZATION_ENDPOINT=http://localhost/auth
OIDC_TOKEN_ENDPOINT=http://localhost/token
OIDC_USERINFO_ENDPOINT=http://localhost/userinfo

# App
ENV=development
DEBUG=true